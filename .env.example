# ================================================
# CareBook Clinic Bot - Cấu hình môi trường
# ================================================
# Copy file này thành .env và điền thông tin:
#   cp .env.example .env
# ================================================

# Telegram Bot Token (lấy từ @BotFather trên Telegram)
BOT_TOKEN=your_bot_token_here

# Admin Telegram ID (gửi /myid cho bot để lấy ID)
ADMIN_ID=your_telegram_id_here

# ================================================
# Ngân hàng 1 (bắt buộc) - Thanh toán QR VietQR
# ================================================
# Tra mã BIN tại: https://www.vietqr.io/danh-sach-ngan-hang
BANK_BIN=970422
BANK_ACCOUNT=your_bank_account_number
BANK_ACCOUNT_NAME=YOUR_FULL_NAME
BANK_NAME=MB

# ================================================
# Ngân hàng 2 (tùy chọn - cho khách chọn bank)
# ================================================
# Bỏ comment để bật ngân hàng thứ 2
# BANK2_BIN=970436
# BANK2_ACCOUNT=your_second_bank_account
# BANK2_ACCOUNT_NAME=YOUR_FULL_NAME
# BANK2_NAME=VCB

# ================================================
# Thanh toán tự động & Dashboard (SePay Webhook)
# ================================================
SEPAY_API_KEY=your_sepay_api_key
DASHBOARD_TOKEN=your_dashboard_secret_token_here
WEBHOOK_PORT=3000

# ================================================
# Đồng bộ Google Calendar (Lịch khám)
# ================================================
# Để dùng tính năng này, hãy đặt tệp credentials.json vào src/config/
CLINIC_CALENDAR_ID=primary

# ================================================
# Thông tin Phòng khám
# ================================================
SHOP_NAME=CareBook Clinic
SUPPORT_CONTACT=@your_telegram_username

# ================================================
# Zalo Chatbot (lấy từ https://zalo.me/s/botcreator/)
# ================================================
ZALO_BOT_TOKEN=your_zalo_bot_token_here
ZALO_BOT_SECRET_TOKEN=your_zalo_webhook_secret_token_here
